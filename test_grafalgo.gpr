--  test_grafalgo.gpr
--  Version: 0.01
--  Description: GNAT Project file for testing Grafalgo library

with "grafalgo.gpr";

project Test_Grafalgo is

   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("test_grafalgo.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-O0", "-gnata");
   end Compiler;

end Test_Grafalgo;
